# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_KEY=eyJhbGci...   # service_role key — required for server-side writes

# Shared API key guarding the service-role API routes.
# REQUIRED in production: if unset, those routes reject all requests.
NEXT_PUBLIC_SUPERADMIN_API_KEY=generate-a-long-random-string

# Bouncie GPS vehicle integration — https://docs.bouncie.dev/#/
NEXT_PUBLIC_BOUNCIE_CLIENT_ID=attenda
BOUNCIE_CLIENT_SECRET=your-bouncie-secret
NEXT_PUBLIC_BOUNCIE_REDIRECT_URI=https://attendaapp.com/api/bouncie/callback
BOUNCIE_WEBHOOK_SECRET=your-bouncie-api-key

# App URL (used for OAuth redirect URIs)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_...

# Optional: pin a build ID for cache-busting
# BUILD_ID=2026-06-10-001
